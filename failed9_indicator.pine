//@version=6
indicator("Failed 9 — 8AM NY Session", overlay=true, max_boxes_count=50, max_labels_count=500, max_lines_count=500)

// =========================
// VISUAL SETTINGS
// =========================
entryColor      = input.color(color.gray, "Entry Level Color (25%)")
stopColor       = input.color(color.red, "Stop Level Color (12.5%)")
tp1Color        = input.color(color.green, "TP1 Level Color (50%)")
tp2Color        = input.color(color.teal, "TP2 Level Color (Range Extreme)")
fillTransparency = input.int(80, "Fill Transparency", minval=0, maxval=100)
profitZoneColor = input.color(color.green, "Profit Zone Fill Color")
stopZoneColor   = input.color(color.red, "Stop Zone Fill Color")
candle8AMColor  = input.color(color.teal, "8AM Candle Box Color")

// =========================
// LEVEL SETTINGS
// =========================
stop_offset     = input.float(0.125, "Stop Offset (12.5%)", step=0.01)
entry_offset    = input.float(0.25, "Entry Offset (25%)", step=0.01)
tp1_offset      = input.float(0.50, "TP1 Offset (50%)", step=0.01)

// =========================
// DISPLAY SETTINGS
// =========================
labelOnLevels   = input.bool(true, "Show Entry/Stop/TP Labels")
show8AMBox      = input.bool(true, "Show 8AM Candle Box")

// =========================
// 8AM CANDLE DETECTION (NY TIME)
// =========================
nyHour = hour(time, "America/New_York")
is8AMCandle = nyHour == 8 and nyHour[1] != 8

var float ref8AMHigh = na
var float ref8AMLow = na
var int ref8AMTime = na
var int ref8AMBar = na

if is8AMCandle
    ref8AMHigh := high
    ref8AMLow := low
    ref8AMTime := time
    ref8AMBar := bar_index

if nyHour == 8
    if high > ref8AMHigh
        ref8AMHigh := high
    if low < ref8AMLow
        ref8AMLow := low

// =========================
// 8AM CANDLE BOX AND LABELS
// =========================
var box box8AM = na
var label lbl8H = na
var label lbl8L = na

if is8AMCandle and show8AMBox
    if not na(box8AM)
        box.delete(box8AM)
    if not na(lbl8H)
        label.delete(lbl8H)
    if not na(lbl8L)
        label.delete(lbl8L)

if nyHour == 8 and show8AMBox and not na(ref8AMBar)
    if not na(box8AM)
        box.delete(box8AM)
    if not na(lbl8H)
        label.delete(lbl8H)
    if not na(lbl8L)
        label.delete(lbl8L)
    box8AM := box.new(left=ref8AMBar, top=ref8AMHigh, right=bar_index+1, bottom=ref8AMLow, bgcolor=color.new(candle8AMColor, 85), border_color=candle8AMColor)
    lbl8H := label.new(bar_index+1, ref8AMHigh, "8H: " + str.tostring(ref8AMHigh, format.mintick), style=label.style_label_left, color=color.new(color.black, 100), textcolor=candle8AMColor, size=size.small)
    lbl8L := label.new(bar_index+1, ref8AMLow, "8L: " + str.tostring(ref8AMLow, format.mintick), style=label.style_label_left, color=color.new(color.black, 100), textcolor=candle8AMColor, size=size.small)

// =========================
// FAILED 9 SWEEP DETECTION (9AM+ candles)
// =========================
afterSession = nyHour >= 9 and nyHour < 17
candleRange = ref8AMHigh - ref8AMLow

entry25High = ref8AMHigh - (candleRange * entry_offset)
entry25Low = ref8AMLow + (candleRange * entry_offset)

highSwept = afterSession and not na(ref8AMHigh) and high > ref8AMHigh and close <= entry25High and close > ref8AMLow
lowSwept = afterSession and not na(ref8AMLow) and low < ref8AMLow and close >= entry25Low and close < ref8AMHigh

var string dir = na
var float lvlEntry = na
var float lvlStop = na
var float lvlTp1 = na
var float lvlTp2 = na
var int refDay = na
var int signalBar = na

if highSwept and barstate.isconfirmed
    dir := "SHORT"
    lvlEntry := entry25High
    lvlStop := ref8AMHigh - (candleRange * stop_offset)
    lvlTp1 := ref8AMHigh - (candleRange * tp1_offset)
    lvlTp2 := ref8AMLow
    refDay := ref8AMTime
    signalBar := bar_index

if lowSwept and barstate.isconfirmed
    dir := "LONG"
    lvlEntry := entry25Low
    lvlStop := ref8AMLow + (candleRange * stop_offset)
    lvlTp1 := ref8AMLow + (candleRange * tp1_offset)
    lvlTp2 := ref8AMHigh
    refDay := ref8AMTime
    signalBar := bar_index

// =========================
// STATE
// =========================
var string tradeState = "Waiting"
var bool armed = true
var bool done = false

var int lastSeenRefDay = na
if ref8AMTime != lastSeenRefDay
    tradeState := "Waiting"
    armed := true
    done := false
    lastSeenRefDay := ref8AMTime
    dir := na

enterLong = dir == "LONG" and armed and ta.crossover(close, lvlEntry)
enterShort = dir == "SHORT" and armed and ta.crossunder(close, lvlEntry)

if enterLong or enterShort
    tradeState := "TRIGGER"
    armed := false

hitStop = not armed and not done and ((dir == "LONG" and low <= lvlStop) or (dir == "SHORT" and high >= lvlStop))
hitTp1 = not armed and not done and ((dir == "LONG" and high >= lvlTp1) or (dir == "SHORT" and low <= lvlTp1))
hitTp2 = not armed and not done and ((dir == "LONG" and high >= lvlTp2) or (dir == "SHORT" and low <= lvlTp2))

if hitStop
    tradeState := "Stopped"
    done := true

if hitTp2
    tradeState := "TP2 hit"
    done := true
else if hitTp1
    tradeState := "TP1 hit"

// =========================
// DRAWING - Position boxes and lines
// =========================
var line lnEntry = na
var line lnStop = na
var line lnTp1 = na
var line lnTp2 = na
var box profitBox = na
var box stopBox = na

if (highSwept or lowSwept) and barstate.isconfirmed and not na(refDay)
    if not na(lnEntry)
        line.delete(lnEntry)
    if not na(lnStop)
        line.delete(lnStop)
    if not na(lnTp1)
        line.delete(lnTp1)
    if not na(lnTp2)
        line.delete(lnTp2)
    if not na(profitBox)
        box.delete(profitBox)
    if not na(stopBox)
        box.delete(stopBox)
    
    boxWidth = 3
    
    if dir == "SHORT"
        profitBox := box.new(left=bar_index, top=lvlEntry, right=bar_index+boxWidth, bottom=lvlTp2, bgcolor=color.new(profitZoneColor, fillTransparency), border_color=color.new(profitZoneColor, 50))
        stopBox := box.new(left=bar_index, top=lvlStop, right=bar_index+boxWidth, bottom=lvlEntry, bgcolor=color.new(stopZoneColor, fillTransparency), border_color=color.new(stopZoneColor, 50))
    else if dir == "LONG"
        profitBox := box.new(left=bar_index, top=lvlTp2, right=bar_index+boxWidth, bottom=lvlEntry, bgcolor=color.new(profitZoneColor, fillTransparency), border_color=color.new(profitZoneColor, 50))
        stopBox := box.new(left=bar_index, top=lvlEntry, right=bar_index+boxWidth, bottom=lvlStop, bgcolor=color.new(stopZoneColor, fillTransparency), border_color=color.new(stopZoneColor, 50))
    
    lnEntry := line.new(x1=bar_index, y1=lvlEntry, x2=bar_index+boxWidth, y2=lvlEntry, color=entryColor, width=2)
    lnStop := line.new(x1=bar_index, y1=lvlStop, x2=bar_index+boxWidth, y2=lvlStop, color=stopColor, width=2)
    lnTp1 := line.new(x1=bar_index, y1=lvlTp1, x2=bar_index+boxWidth, y2=lvlTp1, color=tp1Color, width=2)
    lnTp2 := line.new(x1=bar_index, y1=lvlTp2, x2=bar_index+boxWidth, y2=lvlTp2, color=tp2Color, width=2)
    
    if labelOnLevels
        entryStr = "Entry: " + str.tostring(lvlEntry, format.mintick)
        stopStr = "Stop: " + str.tostring(lvlStop, format.mintick)
        tp1Str = "TP1: " + str.tostring(lvlTp1, format.mintick)
        tp2Str = "TP2: " + str.tostring(lvlTp2, format.mintick)
        label.new(bar_index, lvlEntry, entryStr, style=label.style_label_left, color=entryColor, textcolor=color.black)
        label.new(bar_index, lvlStop, stopStr, style=label.style_label_left, color=stopColor, textcolor=color.white)
        label.new(bar_index, lvlTp1, tp1Str, style=label.style_label_left, color=tp1Color, textcolor=color.black)
        label.new(bar_index, lvlTp2, tp2Str, style=label.style_label_left, color=tp2Color, textcolor=color.white)

// =========================
// ALERTS
// =========================
alertcondition(highSwept, title="Failed 9 Short Setup", message="8AM high swept - Short trigger")
alertcondition(lowSwept, title="Failed 9 Long Setup", message="8AM low swept - Long trigger")
