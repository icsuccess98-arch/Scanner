//@version=5
indicator("Failed 9 — 8AM NY Session Framework", overlay=true, max_boxes_count=50, max_labels_count=500, max_lines_count=500)

// =========================
// USER SETTINGS
// =========================
sessionHour     = input.int(8, "Session Hour (NY Time)", minval=0, maxval=23)
showTable       = input.bool(true, "Show Dashboard Panel")
boxOpacity      = input.int(85, "Position Box Opacity", minval=0, maxval=100)
labelOnLevels   = input.bool(true, "Show Entry/Stop/TP Labels")

// Offsets as FRACTIONS of the 8AM candle range
stop_offset     = input.float(0.125, "Stop Offset (12.5%)", step=0.01)
entry_offset    = input.float(0.25, "Entry Offset (25%)", step=0.01)
tp1_offset      = input.float(0.50, "TP1 Offset (50%)", step=0.01)

// =========================
// 8AM CANDLE DETECTION (NY TIME)
// =========================
nyHour = hour(time, "America/New_York")
is8AMCandle = nyHour == sessionHour and nyHour[1] != sessionHour

// Store 8AM candle reference levels
var float refHigh = na
var float refLow = na
var int refTime = na

if is8AMCandle
    refHigh := high
    refLow := low
    refTime := time

// =========================
// FAILED 9 SWEEP DETECTION
// =========================
// High Swept: price breaks above 8AM high, then closes back at 25% level
candleRange = refHigh - refLow
entry25High = refHigh - (candleRange * entry_offset)
entry25Low = refLow + (candleRange * entry_offset)

highSwept = not na(refHigh) and high > refHigh and close <= entry25High and close > refLow
lowSwept = not na(refLow) and low < refLow and close >= entry25Low and close < refHigh

// Freeze the most recent signal so charts can reference it
var string dir = na
var float lvlEntry = na
var float lvlStop = na
var float lvlTp1 = na
var float lvlTp2 = na

if highSwept and barstate.isconfirmed
    dir := "SHORT"
    lvlEntry := entry25High
    lvlStop := refHigh + (candleRange * stop_offset)
    lvlTp1 := refHigh - (candleRange * tp1_offset)
    lvlTp2 := refLow

if lowSwept and barstate.isconfirmed
    dir := "LONG"
    lvlEntry := entry25Low
    lvlStop := refLow - (candleRange * stop_offset)
    lvlTp1 := refLow + (candleRange * tp1_offset)
    lvlTp2 := refHigh

// =========================
// STATE: waiting/active/completed
// =========================
var string tradeState = "Waiting for entry..."
var bool armed = true
var bool done = false

// Reset completion when a NEW 8AM candle signal is stamped
var int lastSeenRefTime = na
if refTime != lastSeenRefTime
    tradeState := "Waiting for entry..."
    armed := true
    done := false
    lastSeenRefTime := refTime

// Activate entry
enterLong = dir == "LONG" and armed and ta.crossover(close, lvlEntry)
enterShort = dir == "SHORT" and armed and ta.crossunder(close, lvlEntry)

if enterLong or enterShort
    tradeState := dir + " TRIGGER"
    armed := false

// Completion rules
hitStop = not armed and not done and ((dir == "LONG" and low <= lvlStop) or (dir == "SHORT" and high >= lvlStop))
hitTp1 = not armed and not done and ((dir == "LONG" and high >= lvlTp1) or (dir == "SHORT" and low <= lvlTp1))
hitTp2 = not armed and not done and ((dir == "LONG" and high >= lvlTp2) or (dir == "SHORT" and low <= lvlTp2))

if hitStop
    tradeState := "Stopped"
    done := true

if hitTp2
    tradeState := "TP2 hit"
    done := true
else if hitTp1
    tradeState := "TP1 hit"

// =========================
// DRAWING: lines, labels, and position box
// =========================
var line lnEntry = na
var line lnStop = na
var line lnTp1 = na
var line lnTp2 = na
var label lbDir = na
var box posBox = na

f_reset_drawings() =>
    if not na(lnEntry)
        line.delete(lnEntry)
        lnEntry := na
    if not na(lnStop)
        line.delete(lnStop)
        lnStop := na
    if not na(lnTp1)
        line.delete(lnTp1)
        lnTp1 := na
    if not na(lnTp2)
        line.delete(lnTp2)
        lnTp2 := na
    if not na(lbDir)
        label.delete(lbDir)
        lbDir := na
    if not na(posBox)
        box.delete(posBox)
        posBox := na

// Whenever new signal: clear and redraw
if barstate.isnew and not na(dir) and not na(lvlEntry)
    f_reset_drawings()
    
    // Position box spans ENTRY to TP2
    if dir == "SHORT"
        posBox := box.new(left=bar_index, top=lvlEntry, right=bar_index+100, bottom=lvlTp2, bgcolor=color.new(color.red, 100 - boxOpacity), border_color=color.new(color.red, 0))
    else if dir == "LONG"
        posBox := box.new(left=bar_index, top=lvlTp2, right=bar_index+100, bottom=lvlEntry, bgcolor=color.new(color.lime, 100 - boxOpacity), border_color=color.new(color.lime, 0))
    
    colEntry = color.new(color.yellow, 0)
    colStop = color.new(color.red, 0)
    colTp = color.new(color.teal, 0)
    
    lnEntry := line.new(x1=bar_index, y1=lvlEntry, x2=bar_index+500, y2=lvlEntry, extend=extend.right, color=colEntry, width=2)
    lnStop := line.new(x1=bar_index, y1=lvlStop, x2=bar_index+500, y2=lvlStop, extend=extend.right, color=colStop, width=2)
    lnTp1 := line.new(x1=bar_index, y1=lvlTp1, x2=bar_index+500, y2=lvlTp1, extend=extend.right, color=color.new(color.lime, 0), width=2)
    lnTp2 := line.new(x1=bar_index, y1=lvlTp2, x2=bar_index+500, y2=lvlTp2, extend=extend.right, color=colTp, width=2)
    
    if labelOnLevels
        label.new(bar_index, lvlEntry, "Entry: " + str.tostring(lvlEntry, format.mintick), style=label.style_label_left, color=color.new(color.yellow, 0), textcolor=color.black)
        label.new(bar_index, lvlStop, "Stop:  " + str.tostring(lvlStop, format.mintick), style=label.style_label_left, color=color.new(color.red, 0), textcolor=color.white)
        label.new(bar_index, lvlTp1, "TP1:   " + str.tostring(lvlTp1, format.mintick), style=label.style_label_left, color=color.new(color.lime, 0), textcolor=color.black)
        label.new(bar_index, lvlTp2, "TP2:   " + str.tostring(lvlTp2, format.mintick), style=label.style_label_left, color=color.new(color.teal, 0), textcolor=color.white)
    
    // Direction label
    trigText = (dir == "SHORT" ? "SHORT TRIGGER" : "LONG TRIGGER")
    trigCol = (dir == "SHORT" ? color.new(color.red, 0) : color.new(color.lime, 0))
    lbDir := label.new(bar_index, na(dir) ? close : (dir == "SHORT" ? high : low), trigText, style=label.style_label_down, color=trigCol, textcolor=color.white)

// Keep the box right edge advancing
if not na(posBox)
    box.set_right(posBox, bar_index + 100)

// =========================
// DASHBOARD PANEL (table)
// =========================
var table t = na
if showTable
    if na(t)
        t := table.new(position.bottom_right, 4, 6, frame_color=color.new(color.gray, 70), border_color=color.new(color.gray, 70))
    
    bg = dir == "SHORT" ? color.new(color.red, 85) : dir == "LONG" ? color.new(color.lime, 85) : color.new(color.gray, 92)
    head = dir == "SHORT" ? "SHORT TRIGGER" : dir == "LONG" ? "LONG TRIGGER" : "Waiting..."
    
    // R:R calculation
    rr = na(lvlEntry) or na(lvlStop) or na(lvlTp1) ? na : (
         dir == "SHORT" ? (math.abs(lvlEntry - lvlTp1) / math.abs(lvlStop - lvlEntry)) :
                          (math.abs(lvlTp1 - lvlEntry) / math.abs(lvlEntry - lvlStop)))
    
    potPct = na(lvlEntry) or na(lvlTp1) ? na : (
             dir == "SHORT" ? ((lvlEntry - lvlTp1) / lvlEntry) * 100 : ((lvlTp1 - lvlEntry) / lvlEntry) * 100)
    
    rangeTxt = na(refHigh) or na(refLow) ? "-" : str.tostring(refLow, format.mintick) + " - " + str.tostring(refHigh, format.mintick)
    
    table.cell(t, 0, 0, "Failed 9 Framework", bgcolor=color.new(color.black, 0), text_color=color.silver)
    table.cell(t, 0, 1, head, bgcolor=bg, text_color=color.white)
    table.cell(t, 0, 2, "8AM Candle", text_color=color.silver)
    table.cell(t, 1, 2, str.tostring(sessionHour) + ":00 NY")
    table.cell(t, 2, 2, "Price Range", text_color=color.silver)
    table.cell(t, 3, 2, rangeTxt)
    
    table.cell(t, 0, 3, "Entry", text_color=color.silver)
    table.cell(t, 1, 3, na(lvlEntry) ? "-" : str.tostring(lvlEntry, format.mintick))
    table.cell(t, 2, 3, "Stop", text_color=color.silver)
    table.cell(t, 3, 3, na(lvlStop) ? "-" : str.tostring(lvlStop, format.mintick))
    
    table.cell(t, 0, 4, "TP1 (50%)", text_color=color.silver)
    table.cell(t, 1, 4, na(lvlTp1) ? "-" : str.tostring(lvlTp1, format.mintick))
    table.cell(t, 2, 4, "TP2", text_color=color.silver)
    table.cell(t, 3, 4, na(lvlTp2) ? "-" : str.tostring(lvlTp2, format.mintick))
    
    table.cell(t, 0, 5, "Potential Move", text_color=color.silver)
    table.cell(t, 1, 5, na(potPct) ? "-" : str.tostring(potPct, format.percent))
    table.cell(t, 2, 5, "R:R (to TP1)", text_color=color.silver)
    table.cell(t, 3, 5, na(rr) ? "-" : "1:" + str.tostring(rr, format.mintick))

// =========================
// ALERTS
// =========================
alertcondition(highSwept, title="Failed 9 Short Setup", message="8AM high swept. Short trigger active.")
alertcondition(lowSwept, title="Failed 9 Long Setup", message="8AM low swept. Long trigger active.")
