modules = ["nodejs-20", "postgresql-16", "python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["alsa-lib", "at-spi2-atk", "cairo", "cargo", "chromium", "cups", "dbus", "expat", "gitFull", "glib", "glibcLocales", "gtk3", "imagemagick", "libdrm", "libgbm", "libiconv", "libxcrypt", "libxkbcommon", "mesa", "nspr", "nss", "openssl", "pango", "pkg-config", "playwright-driver", "rustc", "xcodebuild", "xorg.libX11", "xorg.libXcomposite", "xorg.libXdamage", "xorg.libXext", "xorg.libXfixes", "xorg.libXrandr", "zip", "zlib", "unzip"]

[agent]
expertMode = true
integrations = ["python_database:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Sports App"

[[workflows.workflow]]
name = "Sports App"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python sports_app.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[userenv]

[userenv.shared]
RUN_MODE = "ALL"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["gunicorn", "--bind=0.0.0.0:5000", "--workers=2", "--timeout=120", "sports_app:app"]
build = ["pip", "install", "-r", "requirements.txt", "&&", "playwright", "install", "chromium"]
