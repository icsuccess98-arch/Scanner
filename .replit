modules = ["python-3.11"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Run Python"

# Only ONE workflow — executes main.py ONCE
[[workflows.workflow]]
name = "Run Python"
author = "agent"

    [[workflows.workflow.tasks]]
    task = "shell.exec"
    args = "python main.py"

[workflows.workflow.metadata]
outputType = "console"
