modules = ["python-3.11"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Daily Stocks"

[[workflows.workflow]]
name = "Run Daily Stocks"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python stocks.py"

[workflows.workflow.metadata]
outputType = "console"

# -----------------------------------------------------
# DEFAULT ENV
# -----------------------------------------------------
[userenv]

[userenv.shared]
RUN_MODE = "STOCKS"
