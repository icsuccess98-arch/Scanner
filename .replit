modules = ["python-3.11"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

# -----------------------------------------------------
# WORKFLOW: Run Stocks Daily (Discord Only)
# -----------------------------------------------------
[[workflows.workflow]]
name = "Run Stocks Daily"
author = "agent"
mode = "parallel"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "RUN_MODE=STOCKS python stocks.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Daily"

[[workflows.workflow]]
name = "Run Daily"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "RUN_MODE=DAILY python main.py"

[workflows.workflow.metadata]
outputType = "console"

# -----------------------------------------------------
# DEFAULT ENV
# -----------------------------------------------------
[userenv]

[userenv.shared]
RUN_MODE = "STOCKS"
