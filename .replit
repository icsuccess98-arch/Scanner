modules = ["python-3.11"]

[nix]
channel = "stable-25_05"

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Daily"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Weekly"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Monthly"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Stocks Daily"

[[workflows.workflow]]
name = "Run Daily"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "RUN_MODE=DAILY python main.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Run Weekly"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "RUN_MODE=WEEKLY python main.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Run Monthly"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "RUN_MODE=MONTHLY python main.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Run Stocks Daily"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "RUN_MODE=DAILY python stocks.py"

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
RUN_MODE = "ALL"
