modules = ["python-3.11"]

[nix]
channel = "stable-25_05"
packages = ["cargo", "libiconv", "libxcrypt", "openssl", "pkg-config", "rustc"]

[agent]
expertMode = true

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Daily"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Weekly"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Run Monthly"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Sports Scanner"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Crypto Scanner"

[[workflows.workflow]]
name = "Run Daily"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "RUN_MODE=DAILY python main.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Run Weekly"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "RUN_MODE=WEEKLY python main.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Run Monthly"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "RUN_MODE=MONTHLY python main.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Sports Scanner"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python sports_scanner.py"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Crypto Scanner"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python crypto_scanner.py"

[workflows.workflow.metadata]
outputType = "console"

[userenv]

[userenv.shared]
RUN_MODE = "ALL"
CRYPTO_DISCORD_WEBHOOK = "https://discord.com/api/webhooks/1454128407293071393/kxpMSHKwzCqgcCdt-P3S3pqqJ_oCYaJ8wCujtzYI42c4-4hxpmxI59pPNM5ppoqueXC4"
