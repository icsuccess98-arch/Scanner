# ============================================================
# SPORTS BETTING APP - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values
# Required variables are marked with [REQUIRED]

# ============================================================
# FLASK CONFIGURATION
# ============================================================

# Secret key for Flask sessions [REQUIRED for production]
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=your-secret-key-here
FLASK_SECRET_KEY=your-flask-secret-key

# Debug mode (set to 'true' for development)
FLASK_DEBUG=false

# ============================================================
# DATABASE [REQUIRED]
# ============================================================

# PostgreSQL connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/sports_betting

# ============================================================
# BETTING APIs
# ============================================================

# The Odds API - for live odds data
# Get key from: https://the-odds-api.com/
ODDS_API_KEY=your-odds-api-key

# ============================================================
# WEATHER API (for outdoor sports)
# ============================================================

# OpenWeatherMap API - for weather data on outdoor games
# Get key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your-openweather-key

# ============================================================
# SPORTS DATA APIs (Optional)
# ============================================================

# KenPom API - for advanced CBB analytics (if available)
KENPOM_API_KEY=your-kenpom-key

# ============================================================
# NOTIFICATIONS
# ============================================================

# Discord webhook for sports alerts
# Create webhook in Discord Server Settings > Integrations > Webhooks
SPORTS_DISCORD_WEBHOOK=https://discord.com/api/webhooks/...

# Telegram notifications (for main.py stocks scanner)
TELEGRAM_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# Discord webhooks for scheduled reports (main.py)
WEBHOOK_DAILY=https://discord.com/api/webhooks/.../daily
WEBHOOK_WEEKLY=https://discord.com/api/webhooks/.../weekly
WEBHOOK_MONTHLY=https://discord.com/api/webhooks/.../monthly

# ============================================================
# APPLICATION SETTINGS
# ============================================================

# Run mode for scheduled jobs: ALL, NBA, CBB, NHL, NFL, CFB
RUN_MODE=ALL

# ============================================================
# LOGGING
# ============================================================

# Log format: 'json' for production monitoring, 'text' for development
LOG_FORMAT=text

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================
# CRYPTO (if using crypto_main.py)
# ============================================================

# Coinbase API credentials
COINBASE_API_KEY=your-coinbase-api-key
COINBASE_PRIVATE_KEY=your-coinbase-private-key
